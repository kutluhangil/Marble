# OpenSky Network (optional) — enables the live flights layer.
# Without these, the flights layer is disabled gracefully.
# Create a client at https://opensky-network.org/ (OAuth2 client credentials).
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Public site URL, used for canonical/OG metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
